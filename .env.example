# Copy to .env and adjust. Everything has a sane local default — the only thing
# you MUST set for real AI conversations is an API key (or leave AI_PROVIDER=mock).

# ── AI ────────────────────────────────────────────────────────────────────────
# mock = scripted conversations, no key needed (local testing)
# openai = GPT (recommended: gpt-4o-mini) | anthropic = Claude
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Security (CHANGE IN PRODUCTION) ──────────────────────────────────────────
JWT_SECRET=dev-insecure-secret-change-me
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root
COOKIE_SECURE=false

# ── URLs (set to your real domains in production) ────────────────────────────
PUBLIC_BASE_URL=http://localhost:8080
DASHBOARD_ORIGIN=http://localhost:8081

# ── Email (SMTP) — leave empty to disable email delivery ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Lead Qualifier <leads@yourdomain.com>

# ── Behaviour ────────────────────────────────────────────────────────────────
DEFAULT_PLAN=professional
ENFORCE_QUOTAS=false
MANUAL_SCREEN_MINUTES=9
IDLE_ABANDON_MINUTES=30
MAX_MESSAGES_PER_CONV=60

# ── Feature flags (all default true) ─────────────────────────────────────────
FEATURE_PROACTIVE_TRIGGERS=true
FEATURE_EXIT_INTENT=true
FEATURE_QUICK_REPLIES=true
FEATURE_EMAIL_DELIVERY=true
FEATURE_SLACK_DELIVERY=true
FEATURE_WEBHOOK_DELIVERY=true
FEATURE_WEEKLY_REPORTS=true
FEATURE_PUBLIC_API=true
FEATURE_HANDOFF=true
FEATURE_MULTILANG=true
